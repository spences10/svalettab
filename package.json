{
	"name": "svalettab",
	"version": "0.0.3",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vp exec vite dev",
		"build": "vp exec vite build",
		"build:extension": "node --experimental-strip-types scripts/build-extension.ts",
		"preview": "vp exec vite preview",
		"prepare": "vp exec svelte-kit sync || echo ''",
		"check": "vp check && vp exec svelte-kit sync && vp exec svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "vp exec svelte-kit sync && vp exec svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "vp check --fix",
		"lint": "vp check",
		"test:unit": "vp exec vitest",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "vp exec playwright test",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "git tag v$npm_package_version && git push origin v$npm_package_version"
	},
